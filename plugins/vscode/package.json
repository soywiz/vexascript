{
  "name": "mylang-vscodeext",
  "displayName": "MyLang",
  "description": "VS Code support for MyLang (.my) using the bundled MyLang LSP",
  "version": "0.0.1",
  "publisher": "mylang",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mylang",
    "workspaceContains:**/*.my",
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mylang",
        "aliases": [
          "MyLang",
          "mylang"
        ],
        "extensions": [
          ".my"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/mylang-file.svg",
          "dark": "./icons/mylang-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "mylang",
        "scopeName": "source.mylang",
        "path": "./syntaxes/mylang.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MyLang",
      "properties": {
        "mylang.referenceCodeLens.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show inline reference counts (e.g. '2 references') above declarations."
        }
      }
    }
  },
  "scripts": {
    "lint": "echo \"No lint configured\""
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
