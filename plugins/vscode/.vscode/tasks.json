{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mylang: install plugin deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "mylang: build compiler from plugin",
      "type": "shell",
      "command": "pnpm",
      "args": ["--dir", "../..", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "mylang: prepare from plugin",
      "dependsOn": [
        "mylang: install plugin deps",
        "mylang: build compiler from plugin"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
