{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vexa: install plugin deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "vexa: bundle extension from plugin",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "bundle-extension"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "vexa: prepare from plugin",
      "dependsOn": [
        "vexa: install plugin deps",
        "vexa: bundle extension from plugin"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
