{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run VexaScript Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "preLaunchTask": "vexa: prepare from plugin",
      "autoAttachChildProcesses": true
    }
  ]
}
