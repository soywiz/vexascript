{
  "name": "@mylang/monaco-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"lsp-server,vite\" --prefix-colors \"cyan,magenta\" \"node server.mjs\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^8.2.0",
    "monaco-editor": "^0.52.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
