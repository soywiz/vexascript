<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="Learn VexaScript through syntax guides, examples, and embedded Monaco editors.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="alternate icon" type="image/png" href="/favicon.png">
    <link rel="stylesheet" href="{{ generatedAssetHrefs.siteCss }}">
    <link rel="stylesheet" href="{{ generatedAssetHrefs.generatedStyleCss }}">
  </head>
  <body>
    {% set currentUrl = page.url or "/" %}
    <header class="site-header">
      <a class="brand" href="/">
        <img class="brand-icon" src="/favicon.svg" alt="" aria-hidden="true">
        <span>VexaScript</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="/blog"{% if currentUrl.startsWith("/blog") %} aria-current="page"{% endif %}>Blog</a>
        <a href="/quickstart"{% if currentUrl.startsWith("/quickstart") %} aria-current="page"{% endif %}>Quickstart</a>
        <a href="/syntax"{% if currentUrl.startsWith("/syntax") %} aria-current="page"{% endif %}>Syntax</a>
        <a href="/cli"{% if currentUrl.startsWith("/cli") %} aria-current="page"{% endif %}>CLI</a>
        <a href="/samples"{% if currentUrl.startsWith("/samples") %} aria-current="page"{% endif %}>Samples</a>
        <a href="/playground"{% if currentUrl.startsWith("/playground") %} aria-current="page"{% endif %}>Playground</a>
        <a href="/embed"{% if currentUrl.startsWith("/embed") %} aria-current="page"{% endif %}>Embed</a>
      </nav>
    </header>
    <main>{{ content | safe }}</main>
    <footer class="site-footer">© {% year %} VexaScript by Soywiz Software. Built with 11ty and Monaco.</footer>
    <script
      src="{{ generatedAssetHrefs.generatedEmbedJs }}"
      onload="if (window.VexaScriptEmbeds) window.dispatchEvent(new Event('vexa-embeds-ready'))"
    ></script>
  </body>
</html>
