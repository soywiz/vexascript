<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="Learn VexaScript through syntax guides, examples, and embedded Monaco editors.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="{{ generatedAssetHrefs.siteCss }}">
    <link rel="stylesheet" href="{{ generatedAssetHrefs.generatedStyleCss }}">
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img class="brand-icon" src="/favicon.svg" alt="" aria-hidden="true">
        <span>VexaScript</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="/blog/">Blog</a>
        <a href="/syntax/">Syntax</a>
        <a href="/syntax/differences/">vs TypeScript</a>
        <a href="/cli/">CLI</a>
        <a href="/#examples">Examples</a>
        <a href="/playground/">Playground</a>
        <a href="/embed/">Embed</a>
      </nav>
    </header>
    <main>{{ content | safe }}</main>
    <footer class="site-footer">© {% year %} VexaScript by Soywiz Software. Built with 11ty and Monaco.</footer>
    <script
      src="{{ generatedAssetHrefs.generatedEmbedJs }}"
      onload="if (window.VexaScriptEmbeds) window.dispatchEvent(new Event('vexa-embeds-ready'))"
    ></script>
  </body>
</html>
