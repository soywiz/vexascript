---
layout: layout.njk
---
<section class="section">
  <article class="card blog-article">
    <p class="eyebrow">{{ category }}</p>
    <h1>{{ title }}</h1>
    <div class="blog-meta">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% if version %}<span>Version {{ version }}</span>{% endif %}
    </div>
    {{ content | safe }}
    <div class="actions">
      <a class="button secondary" href="/blog">Back to blog</a>
      <a class="button secondary" href="/">Visit the homepage</a>
    </div>
  </article>
</section>
