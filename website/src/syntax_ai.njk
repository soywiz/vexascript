---
layout: layout.njk
title: VexaScript for AI Agents
permalink: /syntax/ai.html
---
<section class="doc-shell">
  <article class="doc-content agents-example">
    <div class="agents-example-header">
      <div class="agents-example-intro">
        <h2 class="agents-example-title">AGENTS.md template for AI agents</h2>
        <p>Drop this file into any repository so AI agents can write and edit <code>.vx</code> files correctly. It assumes TypeScript knowledge and only covers VexaScript-specific additions — keeping token usage low.</p>
        <p>For the full human-readable differences guide see <a href="/syntax">Syntax differences</a>, or the <a href="/syntax/full">complete syntax reference</a>.</p>
      </div>
      <button class="button secondary agents-copy-btn" id="agentsCopyBtn">Copy to clipboard</button>
    </div>
    {{ agentsDocumentHtml | safe }}
  </article>

  <script>
    var _agentsMd = {{ agentsDocumentRaw | jsonEncode | safe }};
    document.getElementById('agentsCopyBtn').addEventListener('click', function() {
      var btn = this;
      navigator.clipboard.writeText(_agentsMd).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy to clipboard'; }, 2000);
      });
    });
  </script>
</section>
