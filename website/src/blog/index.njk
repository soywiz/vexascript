---
layout: layout.njk
title: VexaScript Blog
permalink: /blog.html
---
<section class="section">
  <div class="section-heading">
    <p class="eyebrow">Blog</p>
    <h1>News from the VexaScript project</h1>
    <p class="lead">Release announcements, roadmap milestones, and practical updates for people following the language.</p>
  </div>
  <div class="blog-list">
    {% for post in collections.blog | reverse %}
    <article class="card">
      <div class="blog-meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        {% if post.data.category %}<span>{{ post.data.category }}</span>{% endif %}
      </div>
      <h2><a href="{{ post.url }}" style="text-decoration: none; color: inherit;">{{ post.data.title }}</a></h2>
      {% if post.data.summary %}<p class="blog-summary">{{ post.data.summary }}</p>{% endif %}
      <div class="actions">
        <a class="button" href="{{ post.url }}">Read more</a>
      </div>
    </article>
    {% else %}
    <p>No posts yet.</p>
    {% endfor %}
  </div>
</section>
