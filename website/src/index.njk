<script>
  window.addEventListener("DOMContentLoaded", () => {
    const counterSnippet = `class Counter(var value: int) {
  increment(): int => ++value
}

val counter = Counter(41)
counter.increment()`
    const counterSelection = {
      startLineNumber: 4,
      startColumn: 5,
      endLineNumber: 4,
      endColumn: 22
    }

    MyLangEmbeds.createSimpleEditor("#simple-editor", {
      content: counterSnippet,
      selection: counterSelection
    })

    MyLangEmbeds.createWorkspaceEditor("#workspace-editor", {
      activePath: "/main.my",
      files: [
        {
          path: "/main.my",
          content: counterSnippet
        },
        {
          path: "/notes.my",
          content: `// Same snippet, same initial selection, different host shell.
// This workspace embed exists to compare the website integration against
// the standalone Monaco app using the exact same code sample.`
        }
      ],
      selection: counterSelection
    })
  })
</script>
