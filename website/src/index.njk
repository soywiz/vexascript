    { path: "/main.my", content: "import { greet } from './greeter.my'\nconsole.log(greet('MyLang'))" },
    { path: "/greeter.my", content: "export fun greet(name: string): string { return $\"Hello {name}\" }" }
  ]
})</code></pre>
