  <div class="grid">
    <article class="card">
      <h3>Concise declarations</h3>
      <p>Use <code>fun</code> or <code>function</code>, <code>val</code> for read-only values, and primary-constructor class members. Operator overloading and shorthand functions and properties.</p>
{% highlightVexaScript %}
class Point(val x: number, val y: number) {
  operator+() { return this }
  operator-() => Point(-x, -y)
  operator+(other: Point) => Point(x + other.x, y + other.y)
  operator-(other: Point) => Point(x - other.x, y - other.y)
  operator*(scale: number) => Point(x * scale, y * scale)
  length => Math.hypot(x, y)
}
val point = -Point(1, 2) + Point(3, 4) * 2
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>Null-aware access</h3>
      <p>Optional chaining, non-null assertions, and type analysis help make nullable flows explicit.</p>
{% highlightVexaScript %}
let city = user.address?.city ?? "Unknown"
let name = maybeUser!.name
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>Sync async style</h3>
      <p><code>sync</code> await-less functions automatically await produced promises, while <code>go</code> avoids awaiting for manual orchestration.</p>
{% highlightVexaScript %}
declare class Fetch { arrayBuffer(): Promise<ArrayBuffer> }
declare fun fetch(str: string): Promise<Fetch>

sync fun loadBytes(): Uint8Array {
  return Uint8Array(fetch('file.bin').arrayBuffer())
}
{% endhighlightVexaScript %}
    </article>
  </div>
</section>

<section id="examples" class="section">
  <div class="section-heading">
    <p class="eyebrow">Examples</p>
    <h2>Patterns that teach the language.</h2>
  </div>
  <div class="grid">
    <article class="card">
      <h3>Operator overloading</h3>
      <p>Operator and method overloading and new-less constructions, for concise writing.</p>
{% highlightVexaScript %}
class Vec2(val x: number, val y: number) {
  operator+(other: Vec2) => Vec2(x + other.x, y + other.y)
  operator-(other: Vec2) => Vec2(x - other.x, y - other.y)
}
Vec2(1, 2) + Vec2(3, 4)
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>JSX with Preact</h3>
      <p>Destructuring with types to avoid duplication while being concise.</p>
{% highlightVexaScript %}
import { h } from "preact"

fun Welcome({ name: string }) {
  return <section>Hello {name}</section>
}
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>Implicit property access</h3>
      <p>When no ambiguity happens, <code>this</code> is optional.</p>
{% highlightVexaScript %}
class Counter(var value: int) {
  fun increment(): int => ++value
}
{% endhighlightVexaScript %}
    </article>
  </div>
</section>

