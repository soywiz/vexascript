<script>
  window.addEventListener("DOMContentLoaded", () => {
    MyLangEmbeds.createSimpleEditor("#simple-editor", {
      content: `class Counter(var value: int) {
  fun increment(): int {
    this.value = this.value + 1
    return this.value
  }
}

let counter = Counter(41)
counter.increment()`
    })

    MyLangEmbeds.createWorkspaceEditor("#workspace-editor", {
      activePath: "/main.my",
      files: [
        {
          path: "/main.my",
          content: `import { formatUser } from "./format.my"

class User(val name: string, val score: int)

let user = User("Ada", 42)
formatUser(user.name, user.score)`
        },
        {
          path: "/format.my",
          content: `export fun formatUser(name: string, score: int): string {
  return $"{name} has {score} points"
}`
        }
      ]
    })
  })
</script>
