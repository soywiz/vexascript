<script>
  window.addEventListener("DOMContentLoaded", () => {
    function dedent(strings, ...values) {
      const raw = String.raw({ raw: strings }, ...values).replace(/^\n+/, "")
      const lines = raw.split("\n")
      const indents = lines
        .filter((line) => line.trim() !== "")
        .map((line) => line.match(/^\s*/)?.[0].length ?? 0)
      const margin = indents.length > 0 ? Math.min(...indents) : 0
      return lines.map((line) => line.slice(margin)).join("\n").trim()
    }
    const counterSnippet = dedent`
      class Counter(var value: int) {
        increment(): int => ++value
      }

      val counter = Counter(41)
      counter.increment()

      declare class Fetch { arrayBuffer(): Promise<ArrayBuffer> }
      declare fun fetch(str: string): Promise<Fetch>

      sync fun loadBytes(): Uint8Array {
        return Uint8Array(fetch('file.bin').arrayBuffer())
      }
    `
    const counterSelection = {
      startLineNumber: 4,
      startColumn: 5,
      endLineNumber: 4,
      endColumn: 22
    }

    VexaScriptEmbeds.createSimpleEditor("#simple-editor", {
      content: counterSnippet,
      selection: counterSelection
    })

    VexaScriptEmbeds.createWorkspaceEditor("#workspace-editor", {
      activePath: "/main.vx",
      files: [
        {
          path: "/main.vx",
          content: counterSnippet
        },
        {
          path: "/notes.vx",
          content: `// Same snippet, same initial selection, different host shell.
// This workspace embed exists to compare the website integration against
// the standalone Monaco app using the exact same code sample.`
        }
      ],
      selection: counterSelection
    })
  })
</script>
