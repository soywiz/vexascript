    <article class="card">
      <h3>Concise declarations</h3>
      <p>Use <code>fun</code> or <code>function</code>, <code>val</code> for read-only values, and primary-constructor class members. Operator overloading and shorthand functions and properties.</p>
{% highlightVexaScript %}
class Point(val x: number, val y: number) {
  operator+() { return this }
  operator-() => Point(-x, -y)
  operator+(other: Point) => Point(x + other.x, y + other.y)
  operator-(other: Point) => Point(x - other.x, y - other.y)
  operator*(scale: number) => Point(x * scale, y * scale)
  length => Math.hypot(x, y)
}
val point = -Point(1, 2) + Point(3, 4) * 2
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>Null-aware access</h3>
      <p>Optional chaining, non-null assertions, and type analysis help make nullable flows explicit.</p>
{% highlightVexaScript %}
let city = user.address?.city ?? "Unknown"
let name = maybeUser!.name
{% endhighlightVexaScript %}
    </article>
    <article class="card">
      <h3>Sync async style</h3>
      <p><code>sync</code> await-less functions automatically await produced promises, while <code>go</code> avoids awaiting for manual orchestration.</p>
{% highlightVexaScript %}
declare class Fetch { arrayBuffer(): Promise<ArrayBuffer> }
declare fun fetch(str: string): Promise<Fetch>

sync fun loadBytes(): Uint8Array {
  return Uint8Array(fetch('file.bin').arrayBuffer())
}
{% endhighlightVexaScript %}
    </article>
