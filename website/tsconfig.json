{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "moduleResolution": "Bundler",
    "types": [
      "node",
      "vite/client"
    ],
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "vite.config.ts"
  ]
}
