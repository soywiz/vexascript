val iterator = sequence(2)
val firstYield = iterator.next()
var yieldedTotal = firstYield.value
for (value of iterator) yieldedTotal += value
val finished = iterator.next()
console.log("generator", firstYield.done, firstYield.value, yieldedTotal, finished.done)

val recovered = Promise.reject(Error("bad")).catch((reason: any) => 9)
