console.log("utf16 search", utf16String.startsWith("😀", 1), utf16String.endsWith("é"), utf16String.lastIndexOf("😀"))
val dynamicText: any = "  A😀b  "
console.log("dynamic strings", dynamicText.trim().toUpperCase(), dynamicText.charAt(2), dynamicText.substring(2, 5).length, dynamicText.slice(2, 5).length, dynamicText.repeat(2).length)
console.log("dynamic string methods", dynamicText.trimStart().trimEnd().toLowerCase(), dynamicText.replace("😀", "!").trim(), String.fromCharCode(55357).charCodeAt(0))
console.log("math-regex", Math.max(3, 7), Math.round(2.6), /vexa/i.test("VEXA"))

val huge: bigint = 123456789012345678901234567890n
val hugeDivisor = 9876543210n
val parsedHuge = BigInt("999999999999999999999999999999")
console.log("bigint-arithmetic", huge + parsedHuge, huge - hugeDivisor, huge * hugeDivisor, huge / hugeDivisor, huge % hugeDivisor, -huge)
console.log("bigint-bits", huge > hugeDivisor, 2n ** 100n, -5n >> 1n, -5n & 3n, 5n << 70n)
console.log("bigint-signed", -17n / 5n, -17n % 5n, 17n / -5n, 17n % -5n, ~5n, -5n | 2n, -5n ^ 2n)
val incrementedHuge = [1n, huge].map((value: bigint) => value + 1n)
console.log("bigint-values", incrementedHuge.join("|"), [1n, "x"].join("|"), typeof huge, Boolean(0n), Number(42n))
console.log("bigint-prefixes", BigInt("0xff"), BigInt("0b101"), BigInt("0o77"), BigInt(" 42 "))

