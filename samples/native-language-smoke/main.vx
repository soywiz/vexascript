val flattenedPromise = await Promise.resolve(Promise.resolve(11))
val preservedRejection = await Promise.reject("why").catch((reason: any) => reason)
console.log("promise assimilation", flattenedPromise, preservedRejection)
val raced = await Promise.race([Promise.resolve(5), Promise.resolve(6)])
val settled = await Promise.allSettled([Promise.resolve(7), Promise.reject(Error("settled rejection"))])
val firstAny = await Promise.any([Promise.reject(Error("ignored")), Promise.resolve(8)])
console.log("promise combinators", raced, settled.length, firstAny)
console.log("async", await asyncValue(), await doubledAsync())
