import { ImportedStructuralBox, importedDouble, importedLabel } from "./support.vx"

enum Permission {
  None,
  Read = 1,
  Write = Read << 1,
  All = Read | Write
}

type Scores = int[]

class Leaf(val value: int)

interface Meter {
  var value: int
  val label: string
  val leaf: Leaf
  fun add(delta: int): int
}

class Counter(var value: int, val label: string, val leaf: Leaf) : Meter {
  override fun add(delta: int): int {
    value += delta
    return value
  }

  fun addAgain(delta: int): int => add(delta)
}

interface Greeter {
  fun greet(prefix: string): string
}

interface NativeTransformer {
  val label: string
  fun apply(value: int): int
}

interface ImportedStructuralValue {
  var value: int
}

fun runNativeTransformer(transformer: NativeTransformer, value: int): int => transformer.apply(value)

class English(val name: string) : Greeter {
  override fun greet(prefix: string): string => prefix + " " + name
}

class Spanish(val name: string) : Greeter {
  override fun greet(prefix: string): string => prefix + ", " + name
}

class NumberBox(var value: int) {
  operator+(other: NumberBox): NumberBox => NumberBox(value + other.value)
  operator-(): NumberBox => NumberBox(-value)
  operator<=>(other: NumberBox): int => value <=> other.value
  operator[](offset: int): int => value + offset
  operator[]=(next: int, offset: int): void { value = next + offset }
}

class Bag(val values: int[])

class AsyncCallbackHolder {
  private val callback: () => Promise<void> = async (): Promise<void> => {}

  async fun run(): Promise<void> {
    await callback()
  }
}

class OptionalNativeFields {
  var label?: string = undefined
  var leaf?: Leaf = undefined
}

class InheritedOptionalNativeFields extends OptionalNativeFields {
  constructor() {
    super()
  }
}

class DynamicFieldBase

class DynamicFieldChild extends DynamicFieldBase {
  var childOnly: int = 23

  fun declaredAdd(value: int): int => childOnly + value
}

class OptionalDynamicLeft(val shared: Leaf) extends DynamicFieldBase

class OptionalDynamicRight(val shared: Leaf) extends DynamicFieldBase

class DescriptorTarget(var visible: int, var hidden: int)

fun optionalDescriptorVisible(target?: DescriptorTarget): any => target?.visible

fun defaultFromReceiver(receiver: DynamicFieldChild, value: int = receiver.childOnly): int => value

class ConstructorBase {
  constructor(public baseValue: int) {}
}

class ConstructorChild extends ConstructorBase {
  constructor(public readonly ownValue: int) {
    super(ownValue + 1)
  }

  fun total(): int => baseValue + ownValue
}

class NativeBox<T>(val value: T) {
  fun get(): T => value
  fun echo<U>(other: U): U => other
}

class NativeDefaultBox<T = bigint>(val value: T)

class GenericArrayHolder<T>(val items: T[])

fun mutateGenericArray(holder: GenericArrayHolder<int>): int {
  holder.items[0] = 9
  return holder.items[0]
}

fun nativeSingleton<T>(value: T): T[] => [value]

fun nativeRecursiveFirst<T>(values: T[], index: int): T {
  if (index <= 0) return values[0]
  return nativeRecursiveFirst(values, index - 1)
}

fun capturedNullishArray(): string {
  var values: int[] | null = null
  val getValues = (): int[] => {
    values ??= [4]
    return values!
  }
  val first = getValues()
  val second = getValues()
  first.push(5)
  return `${second.length}:${second[1]}`
}

fun scopedResult<T>(action: () => T): T {
  try {
    return action()
  } finally {
  }
}

fun scopedVoid(action: () => void) {
  try {
    action()
  } finally {
  }
}

fun scopedCallbackSemantics(): string {
  var value = 1
  scopedVoid(() => { value += 1 })
  return scopedResult(() => `${value}:ok`)
}

async fun nativePromised<T>(value: T): Promise<T> {
  return value
}

fun * nativeRepeated<T>(value: T): T {
  yield value
}

class Animal {
  fun speak(): string => "base"
}

class Dog extends Animal {
  override fun speak(): string => super.speak() + "!"
}

class Cat extends Animal {
  override fun speak(): string => super.speak() + "?"
}

fun chooseAnimal(dog?: Dog): Animal => dog ?? Cat()

fun dogSound(dog: Dog): string => dog.speak()

fun narrowedAnimalSound(animal: Animal): string {
  if (animal is Dog) return dogSound(animal)
  return animal.speak()
}

fun render(meter: Meter): string {
  meter.value += 2
  meter.value++
  return `${meter.label}:${meter.value}:${meter.leaf.value}`
}

fun optionalMeterLabel(meter: Meter | null): string => (meter?.label ?? "missing") as string

fun greet(greeter: Greeter, prefix: string): string => greeter.greet(prefix)

fun add(value: int, delta: int = 1): int => value + delta

fun nativeIdentity<T>(value: T): T => value

fun <T> Array<T>.nativeFirstOr(fallback: T): T {
  return length > 0 ? this[0] : fallback
}

fun <T> Array<T>.nativeFirstOrElse(fallback: T): T {
  return nativeFirstOr(fallback)
}

val <T> Array<T>.nativeDoubledLength: number => length * 2

class NativePoint(val x: int, val y: int)

class NativeView(var x: int, var y: int)

var NativeView.nativePoint: NativePoint {
  get => NativePoint(x, y)
  set {
    x = newValue.x
    y = newValue.y
  }
}

interface NativeReadable<T> {
  val value: T
  fun read(): T
}

interface NativeLabeledReadable<T> extends NativeReadable<T> {
  val label: string
}

class NativeReader<T>(val value: T, val label: string) implements NativeLabeledReadable<T> {
  override fun read(): T => value
}

fun sumDown(value: int): int {
  if (value <= 0) return 0
  return value + sumDown(value - 1)
}

fun classify(value: string): string {
  switch (value) {
    case "native":
      return "compiled"
    default:
      return "other"
  }
}

fun guarded(): int {
  defer console.log("defer")
  try {
    throw Error("expected")
  } catch (error) {
    return 7
  } finally {
    console.log("finally")
  }
}

fun loopControl(): int {
  var total = 0
  for (value of [1, 2, 3]) {
    try {
      if (value == 1) continue
      if (value == 3) break
      total += value
    } finally {
      total += 10
    }
  }
  return total
}

fun labeledControl(): int {
  var total = 0
  outer: for (i of 0 ..< 3) {
    for (j of 0 ..< 3) {
      if (j == 1) continue outer
      if (i == 2) break outer
      total += 1
    }
  }
  return total
}

fun optionalCapturedArrayGuard(): boolean {
  var values: int[] | undefined = undefined
  val assign = { next: int[] -> values = next }
  return values === undefined || values!.length == 0
}

fun optionalCollectionCalls(): string {
  val map: Map<string, int> | undefined = undefined
  val set: Set<int> | undefined = undefined
  val weakMap: WeakMap<Leaf, string> | undefined = undefined
  val weakSet: WeakSet<Leaf> | undefined = undefined
  val key = Leaf(1)
  return `${map?.has("missing") ?? false}:${set?.has(1) ?? false}:${weakMap?.has(key) ?? false}:${weakSet?.has(key) ?? false}`
}

fun nullishCollectionConstruction(
  mapSource?: Map<string, int>,
  setSource?: Set<int>
): string {
  val map = new Map<string, int>(mapSource)
  val set = new Set<int>(setSource)
  return `${map.size}:${set.size}`
}

fun * sequence(limit: int): int {
  for (value of 0 ..< limit) yield value
  yield* [limit, limit + 1]
  return limit + 10
}

async fun asyncValue(): Promise<int> {
  return 20
}

sync fun ioRoundtrip(): string {
  val path = "/tmp/vexa-native-language-smoke.txt"
  await writeTextFile(path, "native io works")
  return await readTextFile(path)
}

sync fun doubledAsync(): int {
  return asyncValue() * 2
}

fun delay(ms: number) => Promise { resolve, reject ->
  setTimeout(resolve, ms)
}

sync fun rootedArrayAcrossAwait(): string {
  val values: string[] = ["before"]
  await delay(0)
  values.push("after")
  return values.join("|")
}

sync fun rootedParameterAcrossAwait(value: Leaf): int {
  await delay(0)
  return value.value
}

fun timerMessage(label: string, value: int) {
  console.log("timer arguments", label, value)
}

