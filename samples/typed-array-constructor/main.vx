// Constructor-only JavaScript runtime globals can be used with VexaScript's
// class-call style and are emitted with `new` so they work at runtime.
const bytes = Uint8Array(7)
bytes[0] = 65
bytes[1] = 66
bytes[6] = 255

console.log(bytes.length)
console.log(`${bytes[0]},${bytes[1]},${bytes[2]},${bytes[6]}`)
console.log(bytes instanceof Uint8Array)
