{
    "compilerOptions": {
        "baseUrl": "./",
        "jsx": "react-jsx",
        "jsxImportSource": "preact",
        "lib": [
            "es2025",
            "dom"
        ],
        "paths": {
            "react": [
                "./node_modules/preact/compat"
            ],
            "react-dom": [
                "./node_modules/preact/compat"
            ],
            "react-dom/*": [
                "./node_modules/preact/compat/*"
            ]
        }
    }
}
