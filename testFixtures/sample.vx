class Map<K, V> {
    a: K
    b: V

    get(key: K): V {
        return this.b
    }
}

fun demoGenerics() {
    const array = []
    array.push(10)

    const map = new Map<string, int>()
    map.a
    map.get("id")
}

console.log("[a]")
await delay(0.1.seconds)
