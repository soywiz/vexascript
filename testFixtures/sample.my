declare class Console {
    log(a: number)
}

declare var console: Console

console.log(42)

for (n in 1...4) {
    console.log(n)
}

class Map<K, V> {
    a: K
    b: V

    get(key: K): V {
        return this.b
    }
}

fun demoGenerics() {
    const map = new Map<string, int>()
    map.a
    map.get("id")
}
