{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mylang: install vscode extension deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/plugins/vscode"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "mylang: build compiler",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "options": {
        "cwd": "${workspaceFolder}/plugins/vscode"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "mylang: prepare vscode extension",
      "dependsOn": [
        "mylang: install vscode extension deps",
        "mylang: build compiler"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
