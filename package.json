{
  "name": "mylang",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js CLI project for a TypeScript-like language with compiler and language server",
  "type": "module",
  "bin": {
    "mylang": "dist/mylang.js"
  },
  "scripts": {
    "build": "tsup",
    "cli": "pnpm build && node dist/mylang.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "vitest": "^2.1.8",
    "typescript": "^5.8.3",
    "tsup": "^8.1.0"
  }
}
